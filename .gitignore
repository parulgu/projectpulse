schema: spec-driven

context: |
  Project: Project Pulse

  Purpose:
  Central workspace for project tracking, meeting intelligence,
  milestone management, action tracking, decision logging,
  project memory, and bug management.

  Architecture:
  - React frontend
  - Python backend
  - SQLite persistence
  - OCI Generative AI via LangChain
  - Local-first deployment

  Key Principles:
  - Project-scoped data
  - Human review before AI-generated content is persisted
  - Local-first operation
  - Graceful AI fallback behavior
  - Backward-compatible schema evolution

rules:
  proposal:
    - Include Problem Statement
    - Include Goals
    - Include Non Goals
    - Include Success Criteria
    - Explain user value

  design:
    - Document database impact
    - Document API impact
    - Document frontend impact
    - Document AI workflow impact
    - Document migration considerations

  tasks:
    - Tasks must be independently testable
    - Include backend tasks
    - Include frontend tasks
    - Include validation tasks
    - Include documentation updates

  spec:
    - Describe observable behavior
    - Prefer capabilities and scenarios
    - Avoid implementation details
    - Use project-scoped terminology consistently